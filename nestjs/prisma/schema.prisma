  @@map("countries")
}

model Zone {
  id        BigInt   @id @default(autoincrement())
  countryId BigInt   @map("country_id")
  name      String
  code      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  country Country?  @relation(fields: [countryId], references: [id])
  Address Address[]

  @@map("zones")
}

model Lookup {
  id        BigInt    @id @default(autoincrement())
  type      String
  key       String
  value     String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  Product   Product[]

  @@map("lookups")
}

// ========================================
// SUBSCRIPTIONS DOMAIN
// ========================================

model Subscription {
  id             BigInt                      @id @default(autoincrement())
  organisationId BigInt                      @map("organisation_id")
  name           String
  description    String
  virtualFormId  BigInt?                     @map("virtual_form_id")
  documentId     BigInt?                     @map("document_id")
  membership     SubscriptionMembership
  membershipType SubscriptionMembership_type @map("membership_type")
  period         SubscriptionPeriod          @default(YEARLY)
  renewals       SubscriptionRenewals        @default(FIXED_END_DATE)
  published      SubscriptionPublished       @default(PUBLISHED)
  createdAt      DateTime                    @default(now()) @map("created_at")
  updatedAt      DateTime                    @updatedAt @map("updated_at")

  // Relations
  organisation  Organisation?              @relation(fields: [organisationId], references: [id])
  priceOptions  SubscriptionPriceOption[]
  priceRenewals SubscriptionPriceRenewal[]
  priceLateFees SubscriptionPriceLateFee[]
  autoRenewal   SubscriptionAutoRenewal?

  @@map("subscriptions")
}

model SubscriptionAutoRenewal {
  id                         BigInt                                  @id @default(autoincrement())
  subscriptionId             BigInt                                  @unique @map("subscription_id")
  enableAutoRenewal          Boolean                                 @default(false) @map("enable_auto_renewal")
  applyToAllSubscriptionFees Boolean                                 @map("apply_to_all_subscription_fees")
  paymentMethod              Boolean                                 @map("payment_method")
  orderExpiryDays            Int                                     @map("order_expiry_days")
  shouldHaveForm             SubscriptionAutoRenewalShould_have_form @default(NO) @map("should_have_form")
  virtualFormId              BigInt?                                 @map("virtual_form_id")
  message                    String
  createdAt                  DateTime                                @default(now()) @map("created_at")
  updatedAt                  DateTime                                @updatedAt @map("updated_at")

  // Relations
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@map("subscription_auto_renewals")
}

model SubscriptionPriceOption {
  id             BigInt   @id @default(autoincrement())
  subscriptionId BigInt   @map("subscription_id")
  name           String
  price          Decimal
  taxRateId      BigInt?  @map("tax_rate_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@map("subscription_price_options")
}

model SubscriptionPriceRenewal {
  id             BigInt   @id @default(autoincrement())
  subscriptionId BigInt   @map("subscription_id")
  name           String
  price          Decimal
  taxRateId      BigInt?  @map("tax_rate_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@map("subscription_price_renewals")
}

model SubscriptionPriceLateFee {
  id             BigInt   @id @default(autoincrement())
  subscriptionId BigInt   @map("subscription_id")
  daysAfterDue   Int      @map("days_after_due")
  feeAmount      Decimal  @map("fee_amount")
  taxRateId      BigInt?  @map("tax_rate_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@map("subscription_price_late_fees")
}

// ========================================
// TENANCY DOMAIN
// ========================================

model Organisation {
  id               BigInt                     @id @default(autoincrement())
  name             String
  seoName          String                     @unique @map("seo_name")
  email            String
  phone            String?
  logo             String?
  website          String?
  description      String?
  freeTrail        Boolean                    @default(true) @map("free_trail")
  freeTrailEndDate DateTime                   @map("free_trail_end_date")
  billingPolicy    OrganisationBilling_policy @default(DEBIT_ORDER) @map("billing_policy")
  isActive         Boolean                    @default(true) @map("is_active")
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @updatedAt @map("updated_at")

  // Relations
  members             Member[]
  configs             OrganisationConfig[]
  configAdmins        OrganisationConfigAdmin[]
  configFinancials    OrganisationConfigFinancial[]
  configMembers       OrganisationConfigMember[]
  configSubscriptions OrganisationConfigSubscription[]
  lists               OrganisationList[]
  roles               OrganisationRole[]
  User                User[]
  Email               Email[]
  EmailTemplate       EmailTemplate[]
  Invoice             Invoice[]
  Payment             Payment[]
  PaymentMethod       PaymentMethod[]
  TaxRate             TaxRate[]
  AccountBalance      AccountBalance[]
  VirtualForm         VirtualForm[]
  Order               Order[]
  Product             Product[]
  Subscription        Subscription[]

  @@map("organisations")
}

model OrganisationConfig {
  id             BigInt   @id @default(autoincrement())
  organisationId BigInt   @map("organisation_id")
  key            String
  value          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organisation Organisation? @relation(fields: [organisationId], references: [id])

  @@map("organisation_configs")
}

model OrganisationRole {
  id             BigInt   @id @default(autoincrement())
  organisationId BigInt   @map("organisation_id")
  name           String
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organisation            Organisation?             @relation(fields: [organisationId], references: [id])
  OrganisationConfigAdmin OrganisationConfigAdmin[]

  @@map("organisation_roles")
}

model OrganisationList {
  id             BigInt   @id @default(autoincrement())
  organisationId BigInt   @map("organisation_id")
  name           String
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organisation Organisation? @relation(fields: [organisationId], references: [id])

  @@map("organisation_lists")
}

model OrganisationConfigAdmin {
  id             BigInt   @id @default(autoincrement())
  organisationId BigInt   @map("organisation_id")
  memberId       BigInt   @map("member_id")
  roleId         BigInt   @map("role_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  organisation Organisation?     @relation(fields: [organisationId], references: [id])
  member       Member?           @relation(fields: [memberId], references: [id])
  role         OrganisationRole? @relation(fields: [roleId], references: [id])

  @@map("organisation_config_admins")
}

model OrganisationConfigFinancial {
  id               BigInt   @id @default(autoincrement())
  organisationId   BigInt   @map("organisation_id")
  currency         String
  vatStatus        Boolean  @default(true) @map("vat_status")
  vatNumber        String   @map("vat_number")
  financialYearEnd String   @map("financial_year_end")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relations
  organisation   Organisation?    @relation(fields: [organisationId], references: [id])
  AccountingCode AccountingCode[]

  @@map("organisation_config_financials")
}

model OrganisationConfigMember {
  id                                           BigInt   @id @default(autoincrement())
  organisationId                               BigInt   @map("organisation_id")
  shouldAuthorizeMembers                       Boolean  @default(false) @map("should_authorize_members")
  require_2fa                                  Boolean  @default(false)
  maxDaysBetween_2fa                           Int      @map("max_days_between_2fa")
  requirePhysicalAddress                       Boolean  @default(false) @map("require_physical_address")
  requirePhysicalAddressForGroups              Boolean  @default(false) @map("require_physical_address_for_groups")
  hasJuniorMembers                             Boolean  @default(false) @map("has_junior_members")
  juniorMemberMaxAge                           Int      @default(18) @map("junior_member_max_age")
  juniorMemberAutoRenewToAdult                 Boolean  @default(false) @map("junior_member_auto_renew_to_adult")
  hasFamilyMembership                          Boolean  @default(false) @map("has_family_membership")
  familyMembershipMaxAdults                    Int      @default(2) @map("family_membership_max_adults")
  familyMembershipMaxJuniors                   Int      @default(2) @map("family_membership_max_juniors")
  hasGroupMembers                              Boolean  @default(false) @map("has_group_members")
  doesEachGroupMemberHaveMembershipNumber      Boolean  @default(true) @map("does_each_group_member_have_membership_number")
  hasMembershipNumbers                         Boolean  @default(true) @map("has_membership_numbers")
  doesMembershipNumbersAutoIncrement           Boolean  @default(true) @map("does_membership_numbers_auto_increment")
  canMemberSignDeclarationForOtherAdultMembers Boolean  @default(false) @map("can_member_sign_declaration_for_other_adult_members")
  promptAdminToRemoveInactiveMembers           Boolean  @default(true) @map("prompt_admin_to_remove_inactive_members")
  maxDaysInactive                              Int      @default(365) @map("max_days_inactive")
  createdAt                                    DateTime @default(now()) @map("created_at")
  updatedAt                                    DateTime @updatedAt @map("updated_at")

  // Relations
  organisation Organisation? @relation(fields: [organisationId], references: [id])

  @@map("organisation_config_members")
}

model OrganisationConfigSubscription {
  id                                      BigInt   @id @default(autoincrement())
  organisationId                          BigInt   @map("organisation_id")
  canMemberHaveMoreThanOneSubscription    Boolean  @default(false) @map("can_member_have_more_than_one_subscription")
  canHaveSubscriptionWithoutMembership    Boolean  @default(false) @map("can_have_subscription_without_membership")
  recentlyExpiredAnnualSubscriptionMonths Int      @default(1) @map("recently_expired_annual_subscription_months")
  recentlyExpiredMonthlySubscriptionDays  Int      @default(30) @map("recently_expired_monthly_subscription_days")
  recentlyExpiredOtherPeriodDays          Int      @default(30) @map("recently_expired_other_period_days")
  renewAnnualSubscriptionMonths           Int      @default(1) @map("renew_annual_subscription_months")
  renewMonthlySubscriptionDays            Int      @default(30) @map("renew_monthly_subscription_days")
  renewOtherSubscriptionDays              Int      @default(30) @map("renew_other_subscription_days")
  forcedJoiningFee                        Boolean  @default(true) @map("forced_joining_fee")
  subscriptionJoiningId                   BigInt?  @map("subscription_joining_id")
  autoRenewalOrderDays                    Int      @default(5) @map("auto_renewal_order_days")
  createdAt                               DateTime @default(now()) @map("created_at")
  updatedAt                               DateTime @updatedAt @map("updated_at")

  // Relations
  organisation Organisation? @relation(fields: [organisationId], references: [id])

  @@map("organisation_config_subscriptions")
}
